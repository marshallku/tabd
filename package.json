{
    "name": "@marshallku/ai-browser",
    "version": "0.2.0",
    "description": "MCP server for AI browser control over Playwright and headless runtimes",
    "type": "module",
    "main": "dist/server/index.js",
    "bin": {
        "ai-browser": "./bin/ai-browser.js"
    },
    "files": [
        "bin",
        "dist",
        "scripts/run-mcp.sh",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/server/index.ts",
        "start": "node dist/server/index.js",
        "prepack": "npm run build",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "changeset publish",
        "test": "npm run build && node --test dist/server/__tests__/*.test.js",
        "typecheck": "tsc --noEmit",
        "smoke:playwright": "node scripts/smoke-playwright.mjs",
        "smoke:fill-and-submit": "node scripts/fill-and-submit.mjs --url 'data:text/html,%3C!doctype%20html%3E%3Chtml%3E%3Cbody%3E%3Cinput%20id%3Demail%3E%3Cbutton%20id%3Dgo%20onclick%3Dwindow.clicked%3D1%3EGo%3C%2Fbutton%3E%3C%2Fbody%3E%3C%2Fhtml%3E' --fill '#email=test@example.com' --click '#go'",
        "e2e:network-logs": "npm run build && node tests/e2e-network-logs.mjs",
        "e2e:installer": "node tests/e2e-installer.mjs",
        "e2e:hover": "npm run build && node tests/e2e-hover.mjs",
        "e2e:cdp-parity": "npm run build && node tests/e2e-cdp-parity.mjs",
        "e2e:cli": "npm run build && node tests/e2e-cli.mjs",
        "e2e:mcp-daemon": "npm run build && node tests/e2e-mcp-daemon.mjs",
        "e2e:wait-url": "npm run build && node tests/e2e-wait-url.mjs",
        "e2e:secrets-cli": "npm run build && node tests/e2e-secrets-cli.mjs",
        "e2e:secrets-persistent": "npm run build && node tests/e2e-secrets-persistent.mjs",
        "e2e:action-queue": "npm run build && node tests/e2e-action-queue.mjs",
        "e2e:drain": "npm run build && node tests/e2e-daemon-drain.mjs",
        "e2e:crash-restore": "npm run build && node tests/e2e-crash-restore.mjs",
        "e2e:rss-monitor": "npm run build && node tests/e2e-rss-monitor.mjs",
        "e2e:run-once": "npm run build && node tests/e2e-run-once.mjs",
        "e2e:spike-parity": "npm run build && cargo build --release --manifest-path crates/ai-browser/Cargo.toml && bash tests/spike-parity.sh",
        "e2e:spike-daemon-compat": "npm run build && cargo build --release --manifest-path crates/ai-browser/Cargo.toml && bash tests/spike-daemon-compat.sh",
        "e2e:cli-direct-smoke": "cargo build --release --manifest-path crates/ai-browser/Cargo.toml && bash tests/cli-direct-smoke.sh"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "playwright-core": "^1.52.0",
        "pngjs": "^7.0.0",
        "ws": "^8.18.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pngjs": "^6.0.5",
        "@types/ws": "^8.5.0",
        "@changesets/cli": "^2.29.5",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
